<h1>Pexels Collection Viewer</h1>
<p>
  Enter a Pexels collection ID to see its photos.
</p>

<p>
  <%= link_to "Photos provided by Pexels", "https://www.pexels.com", target: "_blank", rel: "noopener" %>
</p>

<%= form_with url: root_path, method: :get do %>
  <div>
    <%= label_tag :collection_id, "Collection ID" %>
    <%= text_field_tag :collection_id, params[:collection_id], placeholder: "e.g. 9mp14cx" %>
  </div>

  <div>
    <%= submit_tag "View collection" %>
  </div>
<% end %>

<% if @error_message.present? %>
  <p><%= @error_message %></p>
<% end %>

<% if @photos.present? %>
  <h2>Photos from collection <%= @collection_id %></h2>

  <div class="photos-grid">
    <% @photos.each do |photo| %>
      <article class="photo-card">
        <%= link_to photo["url"], target: "_blank", rel: "noopener" do %>
          <%= image_tag photo.dig("src", "large"), alt: photo["alt"].presence || "Pexels photo" %>
        <% end %>

        <p>
          Photo by
          <%= link_to photo["photographer"], photo["photographer_url"], target: "_blank", rel: "noopener" %>
          on
          <%= link_to "Pexels", photo["url"], target: "_blank", rel: "noopener" %>
        </p>
      </article>
    <% end %>
  </div>
<% end %>